<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lc_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="4dp"
    android:background="#22000000">

    <View
        android:id="@+id/lc_accent_bar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#FF16A34A"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/lc_rank_platform"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#1 OLA"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#AAFFFFFF"
            android:letterSpacing="0.04"/>

        <TextView
            android:id="@+id/lc_net"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="₹54"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/lc_ride_km"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2.6k"
                android:textSize="9sp"
                android:textColor="#999999"/>
            <TextView
                android:id="@+id/lc_selected_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="• shown"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FF16A34A"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>