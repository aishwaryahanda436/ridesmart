<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:elevation="16dp">

    <!-- Left color accent bar — GREEN / ORANGE / RED -->
    <View
        android:id="@+id/accent_bar"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:minHeight="80dp" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp">

        <!-- Row 1: Platform name + Signal verdict -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_platform_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/overlay_text_label"
                android:letterSpacing="0.1" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_signal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <!-- Row 2: Fare (big) + Net profit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp">

            <!-- Fare — largest number, most important -->
            <TextView
                android:id="@+id/tv_fare"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- Right side: net profit + platform+distance stacked -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tv_net_profit_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EST. PROFIT"
                    android:textSize="9sp"
                    android:textColor="@color/overlay_text_label"
                    android:letterSpacing="0.08"
                    android:gravity="end" />

                <TextView
                    android:id="@+id/tv_net_profit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="end" />

                <TextView
                    android:id="@+id/tv_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/overlay_text_detail"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/overlay_divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <!-- Row 3: ₹/km | Pickup | ₹/hr -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ₹/km -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹/KM"
                    android:textSize="9sp"
                    android:textColor="@color/overlay_text_label"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/tv_per_km"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Pickup distance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PICKUP"
                    android:textSize="9sp"
                    android:textColor="@color/overlay_text_label"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/tv_pickup_ratio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- ₹/hr (hidden when no duration) -->
            <LinearLayout
                android:id="@+id/row_per_hour"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹/HR"
                    android:textSize="9sp"
                    android:textColor="@color/overlay_text_label"
                    android:letterSpacing="0.08" />
                <TextView
                    android:id="@+id/tv_per_hour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

        </LinearLayout>

        <!-- Row 4: Auto-dismiss progress bar + tap hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TAP TO DISMISS"
            android:textSize="8sp"
            android:textColor="@color/overlay_text_hint"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="2dp"
            android:letterSpacing="0.15" />

        <!-- Countdown progress bar -->
        <ProgressBar
            android:id="@+id/dismiss_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:max="120"
            android:progress="120"
            android:progressTint="@color/overlay_progress_tint"
            android:progressBackgroundTint="@color/overlay_progress_bg"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

</LinearLayout>
