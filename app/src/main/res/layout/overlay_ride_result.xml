<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:elevation="16dp">

    <!-- Timer bar — drains left to right over 12 seconds -->
    <ProgressBar
        android:id="@+id/dismiss_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="120"
        android:progress="120"
        android:progressTint="#FFEF9F27"
        android:progressBackgroundTint="#22EF9F27" />

    <!-- Accent bar + content row -->
    <LinearLayout
        android:id="@+id/overlay_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left color accent bar -->
        <View
            android:id="@+id/accent_bar"
            android:layout_width="8dp"
            android:layout_height="match_parent"
            android:minHeight="80dp" />

        <!-- Main content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Row 1: Signal verdict -->
            <TextView
                android:id="@+id/tv_signal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/barlow_condensed_bold"
                android:letterSpacing="0.08" />

            <!-- Row 2: Fare + Net profit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="4dp">

                <TextView
                    android:id="@+id/tv_fare"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="40sp"
                    android:fontFamily="@font/ibm_plex_mono_medium"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tv_net_profit_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NET PROFIT"
                        android:textSize="9sp"
                        android:textColor="#88FFFFFF"
                        android:fontFamily="@font/barlow_condensed_regular"
                        android:letterSpacing="0.08"
                        android:gravity="end" />

                    <TextView
                        android:id="@+id/tv_net_profit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:fontFamily="@font/ibm_plex_mono_medium"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="end" />

                    <TextView
                        android:id="@+id/tv_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="#AAFFFFFF"
                        android:gravity="end" />

                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22FFFFFF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp" />

            <!-- Row 3: ₹/km | Pickup | ₹/hr -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹/KM"
                        android:textSize="9sp"
                        android:textColor="#88FFFFFF"
                        android:fontFamily="@font/barlow_condensed_regular"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_per_km"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:fontFamily="@font/ibm_plex_mono_medium"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PICKUP"
                        android:textSize="9sp"
                        android:textColor="#88FFFFFF"
                        android:fontFamily="@font/barlow_condensed_regular"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_pickup_ratio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:fontFamily="@font/ibm_plex_mono_medium"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/row_per_hour"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹/HR"
                        android:textSize="9sp"
                        android:textColor="#88FFFFFF"
                        android:fontFamily="@font/barlow_condensed_regular"
                        android:letterSpacing="0.08" />
                    <TextView
                        android:id="@+id/tv_per_hour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:fontFamily="@font/ibm_plex_mono_medium"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
