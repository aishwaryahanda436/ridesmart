    <string name="app_name">RideSmart</string>
    <string name="accessibility_service_description">
        RideSmart uses Accessibility Service to help drivers with visual, cognitive,
        or motor impairments instantly evaluate ride offer data — reading fare,
        distance, and duration aloud through audio cues, and providing a
        high-contrast, large-text visual signal — eliminating the need to manually
        read multiple data fields while driving.
    </string>

