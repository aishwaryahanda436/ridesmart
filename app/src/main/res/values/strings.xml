    <!-- Disclosure Screen -->
    <string name="disclosure_title">Accessibility Disclosure</string>
    <string name="disclosure_main_text">RideSmart uses the Accessibility Service API to analyze ride offer cards shown by apps like Uber, Ola, and Rapido to help you make safer driving decisions.</string>
    <string name="why_need_title">Why we need it</string>
    <string name="why_need_desc">To automatically read fare and distance details so you can stay focused on the road. This reduces the need to manually calculate profits while driving, enhancing your safety and concentration.</string>
    <string name="privacy_title">Data Privacy</string>
    <string name="privacy_desc">All screen reading happens locally on your device. We do not store, upload, or share your personal data or screen content with any external servers.</string>
    <string name="no_automation_title">No Automation</string>
    <string name="no_automation_desc">RideSmart does not click buttons, perform actions, or interfere with other apps. It only monitors and overlays profit information.</string>

