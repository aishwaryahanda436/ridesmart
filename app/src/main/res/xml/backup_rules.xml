<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude sensitive driver data from cloud backups -->
    <exclude domain="file" path="datastore/ride_history.preferences_pb"/>
    <exclude domain="file" path="datastore/rider_profile.preferences_pb"/>

    <!-- Exclude Room Database files (contain PII like addresses) -->
    <exclude domain="database" path="ride_history_db"/>
    <exclude domain="database" path="ride_history_db-shm"/>
    <exclude domain="database" path="ride_history_db-wal"/>
</full-backup-content>